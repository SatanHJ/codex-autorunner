{
  "RepoSnapshot": {
    "properties": {
      "id": {"type": "string"},
      "path": {"type": "string"},
      "display_name": {"type": "string"},
      "enabled": {"type": "boolean"},
      "auto_run": {"type": "boolean"},
      "worktree_setup_commands": {
        "type": ["null", "array"],
        "items": {"type": "string"}
      },
      "kind": {"type": "string", "enum": ["base", "worktree"]},
      "worktree_of": {"type": ["null", "string"]},
      "branch": {"type": ["null", "string"]},
      "exists_on_disk": {"type": "boolean"},
      "is_clean": {"type": ["null", "boolean"]},
      "initialized": {"type": "boolean"},
      "init_error": {"type": ["null", "string"]},
      "status": {
        "type": "string",
        "enum": [
          "uninitialized",
          "initializing",
          "idle",
          "running",
          "error",
          "locked",
          "missing",
          "init_error"
        ]
      },
      "lock_status": {
        "type": "string",
        "enum": ["unlocked", "locked_alive", "locked_stale"]
      },
      "last_run_id": {"type": ["null", "integer"]},
      "last_run_started_at": {"type": ["null", "string"]},
      "last_run_finished_at": {"type": ["null", "string"]},
      "last_run_duration_seconds": {"type": ["null", "number"]},
      "last_exit_code": {"type": ["null", "integer"]},
      "runner_pid": {"type": ["null", "integer"]},
      "effective_destination": {"type": "object"},
      "chat_bound": {"type": "boolean"},
      "chat_bound_thread_count": {"type": "integer"},
      "pma_chat_bound_thread_count": {"type": "integer"},
      "discord_chat_bound_thread_count": {"type": "integer"},
      "telegram_chat_bound_thread_count": {"type": "integer"},
      "non_pma_chat_bound_thread_count": {"type": "integer"},
      "cleanup_blocked_by_chat_binding": {"type": "boolean"},
      "has_car_state": {"type": "boolean"},
      "resource_kind": {"type": "string", "enum": ["repo"]},
      "mounted": {"type": "boolean"},
      "mount_error": {"type": ["null", "string"]},
      "ticket_flow": {
        "type": ["null", "object"],
        "properties": {
          "status": {"type": "string"},
          "done_count": {"type": "integer"},
          "total_count": {"type": "integer"},
          "current_step": {"type": ["null", "integer"]}
        }
      },
      "ticket_flow_display": {
        "type": ["null", "object"],
        "properties": {
          "status": {"type": "string"},
          "status_label": {"type": "string"},
          "status_icon": {"type": "string"},
          "is_active": {"type": "boolean"},
          "done_count": {"type": "integer"},
          "total_count": {"type": "integer"},
          "run_id": {"type": ["null", "string"]}
        }
      }
    },
    "required": [
      "id",
      "path",
      "display_name",
      "enabled",
      "auto_run",
      "worktree_setup_commands",
      "kind",
      "worktree_of",
      "branch",
      "exists_on_disk",
      "is_clean",
      "initialized",
      "init_error",
      "status",
      "lock_status",
      "last_run_id",
      "last_run_started_at",
      "last_run_finished_at",
      "last_run_duration_seconds",
      "last_exit_code",
      "runner_pid",
      "effective_destination",
      "resource_kind",
      "mounted"
    ]
  },
  "AgentWorkspaceSnapshot": {
    "properties": {
      "id": {"type": "string"},
      "runtime": {"type": "string"},
      "path": {"type": "string"},
      "display_name": {"type": "string"},
      "enabled": {"type": "boolean"},
      "exists_on_disk": {"type": "boolean"},
      "effective_destination": {"type": "object"},
      "resource_kind": {"type": "string", "enum": ["agent_workspace"]}
    },
    "required": [
      "id",
      "runtime",
      "path",
      "display_name",
      "enabled",
      "exists_on_disk",
      "effective_destination",
      "resource_kind"
    ]
  },
  "HubState": {
    "properties": {
      "last_scan_at": {"type": ["null", "string"]},
      "repos": {"type": "array", "items": {"$ref": "RepoSnapshot"}},
      "agent_workspaces": {
        "type": "array",
        "items": {"$ref": "AgentWorkspaceSnapshot"}
      },
      "pinned_parent_repo_ids": {"type": "array", "items": {"type": "string"}}
    },
    "required": [
      "last_scan_at",
      "repos",
      "agent_workspaces",
      "pinned_parent_repo_ids"
    ]
  }
}
